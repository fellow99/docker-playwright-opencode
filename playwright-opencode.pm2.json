{
  "apps": [
    {
      "name": "vnc",
      "script": "/root/vnc.sh",
      "exec_mode": "fork",
      "instances": 1,
      "autorestart": true
    },
    {
      "name": "playwright",
      "script": "npx @playwright/mcp@latest --port 8931 --host 0.0.0.0 --allowed-hosts 'localhost:8931,127.0.0.1:8931,host.docker.internal:8931' --isolated --executable-path /usr/bin/chromium --user-data-dir /data --no-sandbox",
      "exec_mode": "fork",
      "instances": 1,
      "autorestart": true
    },
    {
      "name": "opencode-serve",
      "script": "opencode serve --hostname $OPENCODE_HOSTNAME --port $OPENCODE_PORT",
      "exec_mode": "fork",
      "instances": 1,
      "autorestart": true
    }
  ]
}
